<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cavintergency — Rescuer Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --blue:#1a5cff; --blue-lt:#e8effe; --blue-dk:#0f3db3;
  --red:#dc2626; --red-lt:#fef2f2;
  --amber:#d97706; --amber-lt:#fffbeb;
  --green:#059669; --green-lt:#ecfdf5;
  --teal:#0891b2; --teal-lt:#ecfeff;
  --purple:#7c3aed; --purple-lt:#f5f3ff;
  --bg:#f0f2f8;
  --surface:#ffffff;
  --surface2:#f4f6fb;
  --surface3:#edf0f7;
  --border:rgba(0,0,0,.07);
  --border2:rgba(0,0,0,.12);
  --text:#0d1117;
  --text2:#5a6478;
  --text3:#9aa3b2;
  --r:12px; --r-sm:8px; --r-lg:16px;
  --sidebar:240px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:14px}
h1,h2,h3,.syne{font-family:'Syne',sans-serif}

/* ─── LOGIN ─── */
#login-page{display:flex;min-height:100vh;align-items:stretch}
.login-left{flex:1;background:linear-gradient(140deg,#0a1628 0%,#0d2a6e 50%,#091d55 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px;max-width:480px}
.login-right{flex:1;display:flex;align-items:center;justify-content:center;padding:40px;background:var(--surface)}
.login-emblem{width:64px;height:64px;background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.2);border-radius:18px;display:flex;align-items:center;justify-content:center;margin-bottom:24px}
.login-emblem svg{width:32px;height:32px}
.login-appname{font-family:'Syne',sans-serif;font-size:34px;font-weight:800;color:#fff;letter-spacing:-1px;line-height:1}
.login-desc{font-size:14px;color:rgba(255,255,255,.55);margin-top:10px;line-height:1.7;max-width:320px}
.login-features{margin-top:32px;display:flex;flex-direction:column;gap:14px}
.lf-item{display:flex;align-items:center;gap:12px;color:rgba(255,255,255,.75);font-size:13px}
.lf-dot{width:8px;height:8px;border-radius:50%;background:var(--blue);flex-shrink:0}
.login-form-wrap{width:100%;max-width:400px}
.login-form-title{font-family:'Syne',sans-serif;font-size:26px;font-weight:700;margin-bottom:6px}
.login-form-sub{font-size:14px;color:var(--text2);margin-bottom:28px}
.portal-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:99px;background:var(--red-lt);color:var(--red);font-size:12px;font-weight:600;margin-bottom:24px}
.rsel{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:20px}
.rs-opt{border:1.5px solid var(--border2);border-radius:var(--r);padding:12px 8px;cursor:pointer;text-align:center;transition:all .18s}
.rs-opt:hover{border-color:#aab4d8;background:var(--surface2)}
.rs-opt.sel{border-color:var(--red);background:var(--red-lt)}
.rs-ico{font-size:20px;margin-bottom:4px}
.rs-lbl{font-size:11px;color:var(--text2);font-weight:500}
.rs-opt.sel .rs-lbl{color:var(--red)}
.f-label{display:block;font-size:12px;font-weight:500;color:var(--text2);margin-bottom:5px;margin-top:14px}
.f-input{width:100%;padding:12px 14px;border:1.5px solid var(--border2);border-radius:var(--r-sm);font-size:14px;font-family:'DM Sans',sans-serif;background:var(--surface2);color:var(--text);outline:none;transition:border-color .18s}
.f-input:focus{border-color:var(--blue);background:#fff}
.btn-login{width:100%;padding:14px;background:var(--red);color:#fff;border:none;border-radius:var(--r-sm);font-size:15px;font-weight:600;cursor:pointer;margin-top:18px;font-family:'DM Sans',sans-serif;letter-spacing:.1px;transition:background .18s}
.btn-login:hover{background:#b91c1c}
.login-note{font-size:12px;color:var(--text3);text-align:center;margin-top:16px}

/* ─── APP SHELL ─── */
#app-shell{display:none;min-height:100vh;flex-direction:row}
.sidebar{width:var(--sidebar);background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:fixed;top:0;bottom:0;left:0;z-index:10}
.sb-brand{padding:20px 18px 14px;border-bottom:1px solid var(--border)}
.sb-logo-row{display:flex;align-items:center;gap:10px}
.sb-logo-icon{width:32px;height:32px;background:var(--red);border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sb-logo-icon svg{width:18px;height:18px}
.sb-appname{font-family:'Syne',sans-serif;font-size:15px;font-weight:700}
.sb-loc{font-size:11px;color:var(--text3);margin-top:1px}
.sb-user{display:flex;align-items:center;gap:10px;padding:12px 18px;border-bottom:1px solid var(--border)}
.sb-av{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;flex-shrink:0}
.sb-uname{font-size:13px;font-weight:500}
.sb-urole{font-size:11px;color:var(--text2)}
.nav-section{padding:10px 18px 3px;font-size:10px;color:var(--text3);letter-spacing:.08em;text-transform:uppercase;font-weight:500}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 18px;font-size:13px;color:var(--text2);cursor:pointer;border-left:2px solid transparent;transition:all .15s}
.nav-item:hover{background:var(--surface2);color:var(--text)}
.nav-item.active{color:var(--red);border-left-color:var(--red);background:var(--red-lt);font-weight:500}
.nav-ico{font-size:15px;width:20px;text-align:center}
.sb-online{margin-top:auto;padding:12px 18px;border-top:1px solid var(--border)}
.online-row{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--green);margin-bottom:8px}
.online-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulseDot 2s ease-in-out infinite}
@keyframes pulseDot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.3)}}
.btn-logout{width:100%;padding:8px;background:var(--surface2);border:1px solid var(--border2);border-radius:var(--r-sm);font-size:12px;color:var(--text2);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
.btn-logout:hover{color:var(--red);border-color:var(--red)}

.main{margin-left:var(--sidebar);flex:1;display:flex;flex-direction:column;min-height:100vh}
.topbar{height:52px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 24px;gap:12px;position:sticky;top:0;z-index:5}
.topbar-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:600;flex:1}
.badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:600;white-space:nowrap}
.bd{background:var(--red-lt);color:var(--red)}
.bs{background:var(--green-lt);color:var(--green)}
.bw{background:var(--amber-lt);color:var(--amber)}
.bi{background:var(--blue-lt);color:var(--blue)}
.bt{background:var(--teal-lt);color:var(--teal)}
.bv{background:var(--purple-lt);color:var(--purple)}
.clock-display{font-size:12px;color:var(--text3);font-family:'Syne',sans-serif}

.page-content{flex:1;padding:22px 24px;overflow-y:auto}
.view{display:none;animation:fadeIn .2s ease}
.view.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* ─── CARDS ─── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden;margin-bottom:16px}
.card-header{padding:13px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.card-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:600}
.card-body{padding:16px 18px}

/* METRICS */
.metrics-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.metric{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px 18px}
.metric-label{font-size:11px;color:var(--text2);font-weight:500;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
.metric-value{font-family:'Syne',sans-serif;font-size:28px;font-weight:700;line-height:1}
.metric-sub{font-size:11px;color:var(--text3);margin-top:4px}

/* ALERT CARD */
.alert-feed{display:flex;flex-direction:column;gap:12px}
.alert-item{border-radius:var(--r-lg);padding:15px 16px;border-left:3px solid;transition:all .2s}
.ai-red{background:var(--red-lt);border-color:var(--red)}
.ai-blue{background:var(--blue-lt);border-color:var(--blue)}
.ai-amber{background:var(--amber-lt);border-color:var(--amber)}
.ai-green{background:var(--green-lt);border-color:var(--green)}
.ai-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:6px}
.ai-type{font-family:'Syne',sans-serif;font-size:14px;font-weight:600}
.ai-meta{font-size:12px;color:var(--text2);margin-bottom:8px;line-height:1.5}
.ai-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
.sms-box{background:#071407;border-radius:8px;padding:10px 12px;margin-bottom:10px}
.sms-text{font-size:11px;color:#6ed86e;font-family:monospace;line-height:1.7}
.ai-btns{display:flex;gap:8px}
.btn-accept{padding:8px 18px;background:var(--green);color:#fff;border:none;border-radius:var(--r-sm);font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .15s}
.btn-accept:hover{background:#047857}
.btn-forward{padding:8px 18px;background:var(--surface);color:var(--text2);border:1px solid var(--border2);border-radius:var(--r-sm);font-size:12px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s}
.btn-forward:hover{background:var(--surface2)}
.btn-close{padding:8px 16px;background:var(--surface);color:var(--text3);border:1px solid var(--border);border-radius:var(--r-sm);font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif}
.ai-time{font-size:11px;color:var(--text3);margin-top:8px}

/* WAITING STATE */
.waiting-state{text-align:center;padding:48px 24px}
.waiting-icon{font-size:48px;margin-bottom:14px;opacity:.4}
.waiting-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:600;color:var(--text2);margin-bottom:6px}
.waiting-sub{font-size:13px;color:var(--text3)}

/* MAP */
.map-container{background:#0d1b28;border-radius:var(--r-lg);overflow:hidden;height:320px;position:relative;margin-bottom:16px}
.map-container svg{width:100%;height:100%}
.map-legend{position:absolute;top:12px;left:12px;background:rgba(0,0,0,.65);border-radius:8px;padding:10px 12px;display:flex;flex-direction:column;gap:7px}
.map-legend-item{display:flex;align-items:center;gap:7px;font-size:10px;color:#ccc}
.ml-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}

/* TABLE */
.data-table{width:100%;border-collapse:collapse;font-size:12px}
.data-table th{padding:10px 14px;text-align:left;color:var(--text2);font-weight:600;border-bottom:1px solid var(--border);font-size:11px;text-transform:uppercase;letter-spacing:.05em}
.data-table td{padding:10px 14px;color:var(--text);border-bottom:1px solid var(--border)}
.data-table tr:last-child td{border:none}
.data-table tr:hover td{background:var(--surface2)}
.hash{font-family:monospace;font-size:10px;color:var(--text3)}

/* PROGRESS BAR */
.pb-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.pb-label{font-size:12px;color:var(--text2);width:120px;flex-shrink:0}
.pb-track{flex:1;height:7px;background:var(--surface3);border-radius:99px;overflow:hidden}
.pb-fill{height:100%;border-radius:99px}
.pb-pct{font-size:12px;font-weight:600;color:var(--text);width:30px;text-align:right}

/* RESPONDER CARDS */
.responder-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:16px}
.responder-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden}
.rc-head{padding:12px 14px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)}
.rc-name{font-family:'Syne',sans-serif;font-size:13px;font-weight:600}
.rc-body{padding:12px 14px;display:flex;flex-direction:column;gap:7px}
.rc-stat{display:flex;justify-content:space-between;font-size:12px;color:var(--text2)}
.rc-stat span:last-child{font-weight:500;color:var(--text)}

/* NEW ALERT FLASH */
@keyframes flashIn{0%{transform:translateY(-12px);opacity:0}100%{transform:translateY(0);opacity:1}}
.new-alert-flash{animation:flashIn .4s cubic-bezier(.22,1,.36,1)}

/* RING ANIMATION */
@keyframes ring{0%{transform:rotate(0deg)}10%{transform:rotate(15deg)}20%{transform:rotate(-10deg)}30%{transform:rotate(12deg)}40%{transform:rotate(-8deg)}50%,100%{transform:rotate(0deg)}}
.bell-ring{display:inline-block;animation:ring .6s ease}

/* NOTIFICATION BANNER */
.notif-banner{display:none;position:fixed;top:16px;right:20px;z-index:100;background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:14px 18px;max-width:320px;animation:fadeIn .3s ease}
.notif-banner.show{display:block}
.nb-title{font-size:13px;font-weight:600;color:var(--text);margin-bottom:2px}
.nb-body{font-size:12px;color:var(--text2)}

/* TWO-COL LAYOUT */
.two-col{display:grid;grid-template-columns:1fr 360px;gap:16px}
.full-col{grid-column:1/-1}

/* SECTION TITLE */
.section-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:600;margin-bottom:12px}
.section-subtitle{font-size:12px;color:var(--text2);margin-bottom:14px}

/* RISK ZONES */
.risk-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.risk-card{border-radius:var(--r);padding:12px 14px}
.risk-card-title{font-size:12px;font-weight:600;margin-bottom:4px}
.risk-card-sub{font-size:11px;color:var(--text2)}
.risk-high{background:var(--red-lt);border:1px solid #fca5a5}
.risk-high .risk-card-title{color:var(--red)}
.risk-med{background:var(--blue-lt);border:1px solid #93c5fd}
.risk-med .risk-card-title{color:var(--blue-dk)}
.risk-low{background:var(--amber-lt);border:1px solid #fcd34d}
.risk-low .risk-card-title{color:var(--amber)}
</style>
</head>
<body>

<!-- NOTIFICATION BANNER -->
<div class="notif-banner" id="notif-banner">
  <div class="nb-title" id="nb-title">New alert received</div>
  <div class="nb-body" id="nb-body"></div>
</div>

<!-- ═══════════════ LOGIN ═══════════════ -->
<div id="login-page">
  <div class="login-left">
    <div class="login-emblem">
      <svg viewBox="0 0 32 32" fill="none">
        <path d="M16 3L4 9v7c0 6.5 4.8 12.6 12 14.3 7.2-1.7 12-7.8 12-14.3V9L16 3z" fill="rgba(255,255,255,.15)" stroke="rgba(255,255,255,.5)" stroke-width="1.5"/>
        <path d="M11 16l3.5 3.5 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="login-appname">Cavintergency</div>
    <div class="login-desc">Community Emergency Tracking &amp; Geographic Mapping System for faster response and public issue reporting in Municipality of Cavinti, Laguna.</div>
    <div class="login-features">
      <div class="lf-item"><div class="lf-dot"></div>Real-time incident reports from residents</div>
      <div class="lf-item"><div class="lf-dot"></div>AI-powered incident classification</div>
      <div class="lf-item"><div class="lf-dot"></div>GPS location tracking &amp; mapping</div>
      <div class="lf-item"><div class="lf-dot"></div>Automated SMS alerts to responders</div>
      <div class="lf-item"><div class="lf-dot"></div>Blockchain-secured incident records</div>
    </div>
  </div>
  <div class="login-right">
    <div class="login-form-wrap">
      <div class="portal-badge">🚨 Rescuer Portal</div>
      <div class="login-form-title">Sign in as Rescuer</div>
      <div class="login-form-sub">Choose your unit and enter your credentials to access the dispatch dashboard.</div>
      <div class="rsel">
        <div class="rs-opt sel" id="rs-pnp" onclick="selUnit('pnp',this)"><div class="rs-ico">👮</div><div class="rs-lbl">PNP</div></div>
        <div class="rs-opt" id="rs-bfp" onclick="selUnit('bfp',this)"><div class="rs-ico">🚒</div><div class="rs-lbl">BFP</div></div>
        <div class="rs-opt" id="rs-md" onclick="selUnit('mdrrmo',this)"><div class="rs-ico">🌀</div><div class="rs-lbl">MDRRMO</div></div>
      </div>
      <label class="f-label">Badge / ID number</label>
      <input class="f-input" id="badge-input" value="PNP-2024-0142"/>
      <label class="f-label">Password</label>
      <input class="f-input" type="password" value="••••••••"/>
      <button class="btn-login" onclick="doLogin()">Sign in to Dashboard</button>
      <div class="login-note">Residents use the Resident Mobile App — not this portal.</div>
    </div>
  </div>
</div>

<!-- ═══════════════ APP SHELL ═══════════════ -->
<div id="app-shell">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sb-brand">
      <div class="sb-logo-row">
        <div class="sb-logo-icon">
          <svg viewBox="0 0 18 18" fill="none">
            <path d="M9 1L2 5v4c0 3.8 2.8 7.3 7 8.3 4.2-1 7-4.5 7-8.3V5L9 1z" fill="rgba(255,255,255,.3)" stroke="#fff" stroke-width="1.2"/>
            <path d="M6 9l2.5 2.5 5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <div class="sb-appname">Cavintergency</div>
          <div class="sb-loc">Cavinti, Laguna</div>
        </div>
      </div>
    </div>
    <div class="sb-user">
      <div class="sb-av" id="sb-av">SS</div>
      <div><div class="sb-uname" id="sb-uname">Sgt. Santos</div><div class="sb-urole" id="sb-urole">PNP Officer</div></div>
    </div>
    <div class="nav-section">Operations</div>
    <div class="nav-item active" id="nav-alerts" onclick="navTo('alerts')"><span class="nav-ico">🚨</span>Incoming alerts <span class="badge bd" id="nav-badge" style="margin-left:auto;display:none">0</span></div>
    <div class="nav-item" id="nav-map" onclick="navTo('map')"><span class="nav-ico">🗺️</span>Incident map</div>
    <div class="nav-item" id="nav-responders" onclick="navTo('responders')"><span class="nav-ico">🚒</span>Responders</div>
    <div class="nav-section">Intelligence</div>
    <div class="nav-item" id="nav-ml" onclick="navTo('ml')"><span class="nav-ico">🤖</span>ML classifier</div>
    <div class="nav-item" id="nav-blockchain" onclick="navTo('blockchain')"><span class="nav-ico">🔐</span>Blockchain log</div>
    <div class="nav-section">System</div>
    <div class="nav-item" id="nav-profile" onclick="navTo('profile')"><span class="nav-ico">👤</span>My profile</div>
    <div class="sb-online">
      <div class="online-row"><div class="online-dot"></div>All systems online</div>
      <button class="btn-logout" onclick="doLogout()">Sign out</button>
    </div>
  </div>

  <div class="main">
    <div class="topbar">
      <div class="topbar-title" id="topbar-title">Incoming alerts</div>
      <span class="badge bd" id="tb-badge" style="display:none">0 active</span>
      <div class="clock-display" id="clock">Fri 13 Mar 2026 · 09:18 AM</div>
    </div>
    <div class="page-content">

      <!-- ── ALERTS VIEW ── -->
      <div class="view active" id="v-alerts">
        <div class="metrics-grid">
          <div class="metric"><div class="metric-label">Active alerts</div><div class="metric-value" style="color:var(--red)" id="m-active">0</div><div class="metric-sub">from residents</div></div>
          <div class="metric"><div class="metric-label">Avg. response time</div><div class="metric-value">4.2<span style="font-size:16px;font-weight:400">m</span></div><div class="metric-sub" style="color:var(--green)">38% faster</div></div>
          <div class="metric"><div class="metric-label">Reports today</div><div class="metric-value" id="m-today">0</div><div class="metric-sub">total dispatched</div></div>
          <div class="metric"><div class="metric-label">ML accuracy</div><div class="metric-value">91<span style="font-size:16px;font-weight:400">%</span></div><div class="metric-sub">classifier</div></div>
        </div>

        <div class="two-col">
          <div>
            <div class="section-title">Live incoming from residents <span id="bell" style="display:inline-block">🔔</span></div>
            <div id="no-alerts" class="waiting-state">
              <div class="waiting-icon">📭</div>
              <div class="waiting-title">Waiting for resident reports</div>
              <div class="waiting-sub">When a resident scans an incident via the mobile app, it will appear here instantly in real-time.</div>
            </div>
            <div class="alert-feed" id="alerts-feed"></div>
          </div>
          <div>
            <div class="section-title">Quick map preview</div>
