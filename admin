  document.getElementById('v-' + page).classList.add('active');
  document.getElementById('topbar-title').textContent = {
    alerts:'Incoming alerts', map:'Incident map', responders:'Responder units',
    ml:'ML classifier', blockchain:'Blockchain log', profile:'My profile'
  }[page];
}

let pollInterval;
function startPolling() {
  // Simulate incoming reports from resident app every 8–12 seconds (demo mode)
  let demoIdx = 0;
  function triggerDemo() {
    if (demoIdx < SCAN_DATA.length) {
      deliverReport(SCAN_DATA[demoIdx]);
      demoIdx++;
    }
  }
  // Also check localStorage for real resident app reports
  pollInterval = setInterval(() => {
    try {
      const raw = localStorage.getItem('cvt_latest_report');
      if (raw) {
        const r = JSON.parse(raw);
        if (!r._consumed) {
          r._consumed = true;
          localStorage.setItem('cvt_latest_report', JSON.stringify(r));
          deliverRealReport(r);
        }
      }
    } catch(e) {}
  }, 1500);
}

function deliverRealReport(r) {
  alertCount++; todayCount++;
  updateCounts();
  const d = SCAN_DATA.find(s => s.type.toLowerCase().includes(r.type.toLowerCase().split(' ')[0])) || SCAN_DATA[0];
  const aid = 'alert-' + Date.now();
  addAlertCard(aid, r.type, r.severity, d, r.id, r.time, r.reporter);
  addBlockchainRow(r.id, r.type, r.reporter, r.time);
  showNotif('New alert!', r.type + ' from ' + r.reporter);
  updateML(d);
  d.mapPin.forEach(p => {const el=document.getElementById(p);if(el)el.style.display='block';});
  updateMapLegend(d);
  updateDispatchLog(r.id, r.type, d.dispatch, r.time);
}

function deliverReport(d) {
  alertCount++; todayCount++;
  updateCounts();
  const rid = 'CVT-2026-' + String(1046 + alertCount);
  const now = new Date().toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit'});
  const aid = 'alert-' + Date.now();
  addAlertCard(aid, d.type, d.sev, d, rid, now, 'Juan D.C.');
  addBlockchainRow(rid, d.type, 'Juan D.C.', now);
  showNotif('New alert from resident!', d.type);
  updateML(d);
  d.mapPin.forEach(p => {const el=document.getElementById(p);if(el)el.style.display='block';});
  updateMapLegend(d);
  updateDispatchLog(rid, d.type, d.dispatch, now);
}

function addAlertCard(aid, type, sev, d, rid, time, reporter) {
  document.getElementById('no-alerts').style.display = 'none';
  const feed = document.getElementById('alerts-feed');
  const tags = d.tags.map(t => `<span class="badge ${t.cls}" style="font-size:10px">${t.t}</span>`).join('');
  const wrap = document.createElement('div');
  wrap.className = 'new-alert-flash';
  wrap.innerHTML = `<div class="alert-item ${d.ai_cls}" id="${aid}">
    <div class="ai-head">
      <div class="ai-type" style="color:${d.ai_col}">${type}</div>
      <span class="badge ${d.sev_cls}">${sev}</span>
    </div>
    <div class="ai-meta">From: ${reporter} · ${time} · GPS: 14.2378° N, 121.5642° E · Report ID: ${rid}</div>
    <div class="ai-tags">${tags}</div>
    <div class="sms-box"><div class="sms-text">${(d.sms+rid).replace(/\n/g,'<br>')}</div></div>
    <div class="ai-btns">
      <button class="btn-accept" onclick="acceptAlert('${aid}','${type}')">Accept &amp; respond</button>
      <button class="btn-forward" onclick="forwardAlert('${aid}')">Forward</button>
      <button class="btn-close" onclick="dismissAlert('${aid}')">Dismiss</button>
    </div>
    <div class="ai-time">Received ${time} · Blockchain logged · SMS sent to units</div>
  </div>`;
  feed.prepend(wrap);

  // Notify bell
  const bell = document.getElementById('bell');
  bell.classList.remove('bell-ring');
  void bell.offsetWidth;
  bell.classList.add('bell-ring');
}

function acceptAlert(id, label) {
  const el = document.getElementById(id);
  if (el) {
    el.className = 'alert-item ai-green';
    el.innerHTML = `<div class="ai-head"><div class="ai-type" style="color:var(--green)">Accepted — en route</div><span class="badge bs">En route</span></div><div class="ai-meta">${label} · Navigating to GPS location · ETA: ~4 min</div>`;
    alertCount = Math.max(0, alertCount - 1);
    updateCounts();
  }
}
function forwardAlert(id) {
  const el = document.getElementById(id);
  if (el) { el.style.opacity = '0.45'; el.querySelector('.ai-btns').remove(); }
}
function dismissAlert(id) {
  const el = document.getElementById(id);
  if (el) { el.closest('.new-alert-flash')?.remove() || el.remove(); alertCount=Math.max(0,alertCount-1); updateCounts(); }
}

function updateCounts() {
  document.getElementById('m-active').textContent = alertCount;
  document.getElementById('m-today').textContent = todayCount;
  document.getElementById('profile-recv').textContent = todayCount;
  const badge = document.getElementById('nav-badge');
  const tb = document.getElementById('tb-badge');
  if (alertCount > 0) {
    badge.textContent = alertCount; badge.style.display = 'inline-flex';
    tb.textContent = alertCount + ' active'; tb.style.display = 'inline-flex';
  } else { badge.style.display = 'none'; tb.style.display = 'none'; }
  document.getElementById('rc-pnp-alerts').textContent = todayCount;
  document.getElementById('rc-bfp-alerts').textContent = Math.floor(todayCount * .6);
  document.getElementById('rc-md-alerts').textContent = Math.floor(todayCount * .8);
}

function addBlockchainRow(rid, type, reporter, time) {
  bcBlock++;
  document.getElementById('bc-count').textContent = (1048 + todayCount).toLocaleString();
  const tbody = document.getElementById('bc-tbody');
  const hash = '0x' + Math.random().toString(16).slice(2,6) + '...' + Math.random().toString(16).slice(2,6);
  const phash = '0x' + Math.random().toString(16).slice(2,6) + '...' + Math.random().toString(16).slice(2,6);
  const row = document.createElement('tr');
  row.innerHTML = `<td style="font-weight:500">${bcBlock}</td><td>${rid}</td><td>${type}</td><td>${reporter}</td><td>${time}</td><td class="hash">${hash}</td><td class="hash">${phash}</td><td><span class="badge bd">Active</span></td>`;
  tbody.prepend(row);
}

function updateML(d) {
  document.getElementById('ml-no-data').style.display = 'none';
  document.getElementById('ml-result').style.display = 'block';
  document.getElementById('ml-bars').innerHTML = d.bars.map(b =>
    `<div class="pb-row"><div class="pb-label">${b.l}</div><div class="pb-track"><div class="pb-fill" style="width:${b.p}%;background:${b.c}"></div></div><div class="pb-pct">${b.p}%</div></div>`
  ).join('');
  document.getElementById('ml-verdict').innerHTML = `<div style="font-size:13px;font-weight:600;color:#1e40af">Classified: ${d.type} · ${d.bars[0].p}% confidence</div><div style="font-size:12px;color:var(--text2);margin-top:3px">Dispatching ${d.dispatch} automatically</div>`;
}

function updateMapLegend(d) {
  const leg = document.getElementById('map-legend');
  const legFull = document.getElementById('map-legend-full');
  const item = `<div class="map-legend-item"><div class="ml-dot" style="background:${d.pinCl}"></div>${d.pinLbl}</div>`;
  if (!leg.innerHTML.includes(d.pinLbl)) { leg.innerHTML += item; legFull.innerHTML += item; }
}

function updateDispatchLog(rid, type, dispatch, time) {
  const tb = document.getElementById('dispatch-log');
  if (tb.querySelector('td[colspan]')) tb.innerHTML = '';
  const row = document.createElement('tr');
  row.innerHTML = `<td>${time}</td><td>${rid}</td><td>${type}</td><td>${dispatch}</td><td><span class="badge bd">Active</span></td>`;
  tb.prepend(row);
}

function showPinDetail(type) {
  const map = {accident:'Motorcycle accident · National Rd km 14.2 · 9:18 AM',flood:'Flash flooding · River crossing · 8:45 AM',landslide:'Landslide · Brgy. Sipit · 7:30 AM',fire:'Structure fire · Km 8 · Just now'};
  showNotif('Incident pin', map[type] || type);
}

let notifTimer;
function showNotif(title, body) {
  const el = document.getElementById('notif-banner');
  document.getElementById('nb-title').textContent = title;
  document.getElementById('nb-body').textContent = body;
  el.classList.add('show');
  clearTimeout(notifTimer);
  notifTimer = setTimeout(() => el.classList.remove('show'), 4000);
}
</script>
</body>
</html>
